{
  "name": "mst-cli",
  "version": "0.1.0",
  "description": "Microsoft Teams CLI via Playwright",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "bin": {
    "mst": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "12.1.0",
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "tsx": "4.22.5",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}

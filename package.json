{
  "name": "mst-cli",
  "version": "0.1.0",
  "description": "Microsoft Teams CLI via Playwright",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "bin": {
    "mst": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "15.0.0",
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "tsx": "4.22.5",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
